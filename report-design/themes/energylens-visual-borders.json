{
  "name": "EnergyLens Theme v3",
  "dataColors": [
    "#1D9E75",
    "#06B6D4",
    "#5DCAA5",
    "#F97316",
    "#A855F7",
    "#EAB308",
    "#3B82F6",
    "#EF4444",
    "#C0DD97",
    "#639922"
  ],
  "background": "#0A1628",
  "foreground": "#FFFFFF",
  "foregroundNeutralSecondary": "#94A3B8",
  "foregroundNeutralTertiary": "#64748B",
  "backgroundLight": "#142944",
  "backgroundNeutral": "#0F1F35",
  "tableAccent": "#1D9E75",
  "good": "#5DCAA5",
  "neutral": "#EAB308",
  "bad": "#EF4444",
  "maximum": "#0F6E56",
  "center": "#1D9E75",
  "minimum": "#C0DD97",
  "null": "#94A3B8",
  "visualStyles": {
    "*": {
      "*": {
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#1D9E75" } },
            "radius": 6
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#5DCAA5" } },
            "background": { "solid": { "color": "#0F1F35" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "color": { "solid": { "color": "#94A3B8" } },
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#94A3B8" } },
            "gridlineColor": { "solid": { "color": "#1F2A3D" } }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "color": { "solid": { "color": "#94A3B8" } },
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#94A3B8" } },
            "gridlineColor": { "solid": { "color": "#1F2A3D" } }
          }
        ],
        "legend": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#94A3B8" } },
            "fontSize": 9
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#E5E7EB" } },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#142944" } },
            "transparency": 10
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#5DCAA5" } },
            "background": { "solid": { "color": "#0F1F35" } },
            "fontSize": 10
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E5E7EB" } },
            "background": { "solid": { "color": "#1E293B" } },
            "fontSize": 10
          }
        ],
        "date": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "background": { "solid": { "color": "#334155" } },
            "fontSize": 10
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#5DCAA5" } },
            "fontSize": 9
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0A1628" } },
            "transparency": 0
          }
        ]
      }
    }
  }
}
