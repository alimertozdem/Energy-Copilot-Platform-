{
  "_comment": "LOCAL Seviye-2 test: sim (127.0.0.1:15020) -> http ingest (localhost:8000) -> bronze_iot_readings. Token from env AGENT_TOKEN.",
  "poll_seconds": 5,
  "batch": 10,
  "sink": {
    "type": "http",
    "ingest_url": "http://localhost:8000/ingest/telemetry",
    "token_env": "AGENT_TOKEN"
  },
  "devices": [
    {
      "name": "PV Inverter Sim",
      "host": "127.0.0.1",
      "port": 15020,
      "unit_id": 1,
      "points": [
        { "register": 1, "sensor_type": "pv_ac_power",         "unit": "kW",   "scale": 0.1, "building_id": "B007", "device_id": "B007_INV1", "zone": "Roof PV" },
        { "register": 2, "sensor_type": "pv_energy_today_kwh",  "unit": "kWh",  "scale": 1.0, "building_id": "B007", "device_id": "B007_INV1", "zone": "Roof PV" },
        { "register": 3, "sensor_type": "pv_dc_power",          "unit": "kW",   "scale": 0.1, "building_id": "B007", "device_id": "B007_INV1", "zone": "Roof PV" },
        { "register": 4, "sensor_type": "inverter_temp",        "unit": "degC", "scale": 1.0, "building_id": "B007", "device_id": "B007_INV1", "zone": "Roof PV" },
        { "register": 5, "sensor_type": "irradiance",           "unit": "W/m2", "scale": 1.0, "building_id": "B007", "device_id": "B007_INV1", "zone": "Roof PV" },
        { "register": 6, "sensor_type": "building_power",       "unit": "kW",   "scale": 0.1, "building_id": "B007", "device_id": "B007_INV1", "zone": "Main meter" }
      ]
    }
  ]
}
