# ==========================================================================
# EnergyLens BACKEND — environment variables (Railway service: backend)
# Copy your real values from your local backend/.env. Do NOT commit .env.
# ==========================================================================

# --- Database (existing Supabase Postgres; use the Session Pooler URL, IPv4) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres  (code auto-rewrites to psycopg3)
DATABASE_URL=

# --- Auth (backend issues JWTs; INTERNAL_API_KEY must MATCH the frontend) ---
JWT_SECRET=
INTERNAL_API_KEY=

# --- CORS: comma-separated allowed browser origins. In prod set to the Vercel URL. ---
# Example: https://energylens.vercel.app
CORS_ORIGINS=https://YOUR-FRONTEND-DOMAIN
# Used for absolute links/redirects (resident magic-link, billing return, etc.)
FRONTEND_URL=https://YOUR-FRONTEND-DOMAIN

# --- Power BI embed (service principal) — all 5 REQUIRED or backend won't start ---
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=
PBI_WORKSPACE_ID=
PBI_REPORT_ID=

# --- Fabric SQL Analytics Endpoint (reuses the PBI service principal above) ---
FABRIC_SQL_SERVER=
FABRIC_SQL_DATABASE=
# Optional — driver is preinstalled in the Docker image:
FABRIC_SQL_DRIVER=ODBC Driver 18 for SQL Server
# Optional perf cache (seconds); 0 = disabled:
FABRIC_SQL_CACHE_TTL=45

# --- Copilot LLM (Anthropic credit = 0 → run in mock mode) ---
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=

# --- Stripe billing (OPTIONAL — leave blank to disable Checkout; app still runs) ---
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_BASIC=
# STRIPE_PRICE_MONITOR=
# STRIPE_PRICE_RESIDENTIAL=
# STRIPE_WEBHOOK_SECRET=
# BILLING_PORTAL_RETURN_URL=https://YOUR-FRONTEND-DOMAIN/settings

# --- Fabric auto-bridge automation (OPTIONAL — off by default) ---
# BRIDGE_AUTOMATION_ENABLED=false
# FABRIC_BRIDGE_TENANT_ID=
# FABRIC_BRIDGE_CLIENT_ID=
# FABRIC_BRIDGE_CLIENT_SECRET=
# FABRIC_ONELAKE_HOST=

# PORT is provided automatically by Railway — do not set it manually.
