table '''Date'''
	lineageTag: 10c75965-cac5-4c3d-bf2a-65352e0c61a5
	dataCategory: Time

	measure 'Previous Period Consumption kWh' = ```
			
			CALCULATE(
			    [Total Consumption kWh],
			    PREVIOUSMONTH('''Date'''[Date])
			)
			
			```
		formatString: #,##0.0
		lineageTag: 97e938eb-77af-4e43-83c6-62c6b080cbd0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Consumption Change Pct' = ```
			
			DIVIDE(
			    [Total Consumption kWh] - [Previous Period Consumption kWh],
			    [Previous Period Consumption kWh],
			    0
			) * 100
			
			
			```
		formatString: #,##0.0
		lineageTag: fde30134-843e-4ecc-bcef-1aa6ab429726

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Previous Period Cost EUR' = ```
			
			CALCULATE(
			    [Total Energy Cost EUR],
			    PREVIOUSMONTH('''Date'''[Date])
			)
			
			```
		formatString: #,##0.0
		lineageTag: f58fb9ad-1eaf-4314-aaa8-1ce844b4e2f3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cost Change Pct' =
			
			DIVIDE(
			    [Total Energy Cost EUR] - [Previous Period Cost EUR],
			    [Previous Period Cost EUR],
			    0
			) * 100
		formatString: #,##0.0
		lineageTag: 1ecec01b-b0dc-465c-80d7-66f9fec38de6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YTD Consumption kWh' =
			
			CALCULATE(
			    [Total Consumption kWh],
			    DATESYTD('''Date'''[Date])
			)
		formatString: #,##0.0
		lineageTag: f2a35e98-3c3f-4b98-a04c-57abe9a8553b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YTD CO2 Emissions tCO2' =
			
			CALCULATE(
			    [Total CO2 Emissions tCO2],
			    DATESYTD('''Date'''[Date])
			)
		formatString: #,##0.0
		lineageTag: a92c8d86-7a87-4bca-857b-d71c45c935cd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Week kWh v14' =
			
			// Veri setinin en son tarihinden 8–14 gün öncesi ("geçen hafta penceresi")
			// Örnek: max date = 2026-01-18 → 5–11 Ocak arası
			VAR _maxDate    = CALCULATE ( MAX ( gold_kpi_daily[date] ), REMOVEFILTERS ( '''Date''' ) )
			VAR _weekEnd    = _maxDate - 7      // geçen haftanın son günü
			VAR _weekStart  = _maxDate - 13     // geçen haftanın ilk günü (7 tam gün)
			RETURN
			CALCULATE (
			    [Total Consumption kWh],
			    REMOVEFILTERS ( '''Date''' ),
			    DATESBETWEEN ( '''Date'''[date], _weekStart, _weekEnd )
			)
		formatString: #,##0.0
		lineageTag: f2f25a28-8739-4dbb-ad7f-5a0b689eaef3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Current Week kWh v14' =
			
			// Veri setinin son 7 günü ("mevcut hafta" gibi davranır)
			VAR _maxDate = CALCULATE ( MAX ( '''Date'''[date] ), REMOVEFILTERS ( '''Date''' ) )
			RETURN
			CALCULATE (
			    [Total Consumption kWh],
			    REMOVEFILTERS ( '''Date''' ),
			    DATESINPERIOD ( '''Date'''[date], _maxDate, -7, DAY )
			)
		formatString: #,##0.0
		lineageTag: 9c86dfd4-3fe8-4fed-bf4b-e81ac17df9fb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Week over Week Consumption Pct' =
			
			// Bu hafta tüketimi / geçen hafta tüketimi karşılaştırması (%)
			// Pozitif = artış, Negatif = azalış
			// FORMAT: "0.0" (×100 yapılmış)
			VAR _thisWeek = [Current Week kWh v14]
			VAR _lastWeek = [Last Week kWh v14]
			RETURN
			DIVIDE(_thisWeek - _lastWeek, _lastWeek, BLANK()) * 100
		formatString: #,##0.0
		lineageTag: 1cefc374-c10c-4384-a2fe-3ee44528b189

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Week over Week Arrow v14' =
			
			// C7 — Haftalık tüketim değişimi, ok etiketi olarak
			// Format: General (text ölçüsü — Standard Card visual kullan, KPI değil)
			VAR _thisWeek = [Current Week kWh v14]
			VAR _lastWeek = [Last Week kWh v14]
			VAR _pct      = DIVIDE ( _thisWeek - _lastWeek, _lastWeek, BLANK() ) * 100
			RETURN
			SWITCH (
			    TRUE (),
			    ISBLANK ( _pct ),   "—",
			    _pct > 5,           "▲▲ " & FORMAT (      _pct,  "+0.0" ) & "%",
			    _pct > 0,           "▲ "  & FORMAT (      _pct,  "+0.0" ) & "%",
			    _pct < -5,          "▼▼ " & FORMAT ( ABS ( _pct ), "0.0" ) & "%",
			    _pct < 0,           "▼ "  & FORMAT ( ABS ( _pct ), "0.0" ) & "%",
			                        "→ 0.0%"
			)
		formatString: #,##0.0
		lineageTag: af5ce728-47b5-4ea7-b3dd-0cc894ad33e2

	measure 'Last Week Cost EUR' =
			
			// Geçen haftanın enerji maliyeti (EUR)
			CALCULATE(
			    [Total Energy Cost EUR],
			    '''Date'''[IsLastWeek] = TRUE()
			)
		formatString: #,##0.0
		lineageTag: afda231e-dbf6-4a17-ba5e-8321cf24f66a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Week CO2 Emissions tCO2' =
			
			// Geçen haftanın CO₂ emisyonu (metrik ton)
			CALCULATE(
			    [Total CO2 Emissions tCO2],
			    '''Date'''[IsLastWeek] = TRUE()
			)
		formatString: #,##0.0
		lineageTag: b1ee69f6-4510-4dd7-a9ca-60bfa4a5a844

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Week Peak Demand kW' = ```
			
			// Geçen hafta maksimum güç talebi (kW)
			CALCULATE(
			    [Peak Demand kW],
			    '''Date'''[IsLastWeek] = TRUE()
			)
			
			```
		formatString: #,##0.0
		lineageTag: 140ef063-b0db-4d31-895a-63e3466501c0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Week Solar Generated kWh' =
			
			// Geçen hafta güneş enerjisi üretimi
			CALCULATE(
			    [Total Solar Generated kWh],
			    '''Date'''[IsLastWeek] = TRUE()
			)
		formatString: #,##0.0
		lineageTag: 4aa98ac0-74e1-4c6e-bc83-0f1fad23e593

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'WoW Solar Change Pct' =
			
			// Güneş üretiminde haftalık değişim — hava koşulu etkisini takip için
			VAR _thisWeek = CALCULATE([Total Solar Generated kWh], '''Date'''[IsCurrentWeek] = TRUE())
			VAR _lastWeek = [Last Week Solar Generated kWh]
			RETURN
			DIVIDE(_thisWeek - _lastWeek, _lastWeek, BLANK()) * 100
		formatString: #,##0.0
		lineageTag: 771167d0-2e2f-4772-9f6a-436f1f9173f9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Month kWh v14' =
			
			// Veri setinin son tarihinin bir önceki tam takvim ayı
			// Örnek: max date = 2026-01-18 → Ocak değil, Aralık 2025'in tamamı
			VAR _maxDate        = CALCULATE ( MAX ( gold_kpi_daily[date] ), REMOVEFILTERS ( '''Date''' ) )
			VAR _lastMonthEnd   = DATE ( YEAR ( _maxDate ), MONTH ( _maxDate ), 1 ) - 1
			VAR _lastMonthStart = DATE ( YEAR ( _lastMonthEnd ), MONTH ( _lastMonthEnd ), 1 )
			RETURN
			CALCULATE (
			    [Total Consumption kWh],
			    REMOVEFILTERS ( '''Date''' ),
			    DATESBETWEEN ( '''Date'''[date], _lastMonthStart, _lastMonthEnd )
			)
		formatString: #,##0.0
		lineageTag: abd97cd4-c9b1-491a-81ad-1adb66fbbb71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Current Month kWh v14' =
			
			// Veri setinin son tarihinin içinde bulunduğu ayın 1'inden son tarihe kadar
			VAR _maxDate    = CALCULATE ( MAX ( '''Date'''[date] ), REMOVEFILTERS ( '''Date''' ) )
			VAR _monthStart = DATE ( YEAR ( _maxDate ), MONTH ( _maxDate ), 1 )
			RETURN
			CALCULATE (
			    [Total Consumption kWh],
			    REMOVEFILTERS ( '''Date''' ),
			    DATESBETWEEN ( '''Date'''[date], _monthStart, _maxDate )
			)
		formatString: #,##0.0
		lineageTag: 864cddfa-96b0-4212-8133-2752ce150840

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Month over Month Consumption Pct' =
			
			// Bu ay / geçen ay tüketim değişimi (%)
			// Not: Ay tamamlanmamışsa eksik gün sayısı dikkate alınmaz — tam ay için kullan
			// FORMAT: "0.0"
			VAR _thisMonth = [Current Month kWh v14]
			VAR _lastMonth = [Last Month kWh v14]
			RETURN
			DIVIDE(_thisMonth - _lastMonth, _lastMonth, BLANK()) * 100
		formatString: #,##0.0
		lineageTag: a271448d-8709-4275-a6ad-28a967efbd3f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Month over Month Arrow v14' =
			
			// C9 — Aylık tüketim değişimi, ok etiketi olarak
			// Format: General (text ölçüsü)
			VAR _thisMonth = [Current Month kWh v14]
			VAR _lastMonth = [Last Month kWh v14]
			VAR _pct       = DIVIDE ( _thisMonth - _lastMonth, _lastMonth, BLANK() ) * 100
			RETURN
			SWITCH (
			    TRUE (),
			    ISBLANK ( _pct ),   "—",
			    _pct > 10,          "▲▲ " & FORMAT (      _pct,  "+0.0" ) & "%",
			    _pct > 0,           "▲ "  & FORMAT (      _pct,  "+0.0" ) & "%",
			    _pct < -10,         "▼▼ " & FORMAT ( ABS ( _pct ), "0.0" ) & "%",
			    _pct < 0,           "▼ "  & FORMAT ( ABS ( _pct ), "0.0" ) & "%",
			                        "→ 0.0%"
			)
		formatString: #,##0.0
		lineageTag: d5b3a642-c8bc-4be8-8af8-0d8cd578795d

