		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MoM CO2 Change Pct' =
			
			// CO₂ değişimi ay bazında — emisyon azaltma hedefi takibi için
			VAR _thisMonth = CALCULATE([Total CO2 Emissions tCO2], '''Date'''[IsCurrentMonth] = TRUE())
