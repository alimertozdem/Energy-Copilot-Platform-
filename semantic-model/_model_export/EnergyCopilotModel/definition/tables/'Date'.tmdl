	measure 'MoM Cost Change Pct' =
			
			// Maliyet değişimi ay bazında
			VAR _thisMonth = CALCULATE([Total Energy Cost EUR], '''Date'''[IsCurrentMonth] = TRUE())
			VAR _lastMonth = [Last Month Cost EUR]
