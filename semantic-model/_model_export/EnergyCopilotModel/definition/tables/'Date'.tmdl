	measure 'Card: Last Week vs Previous Week Pct' =
			
			// Page 1 KPI card: Geçen hafta / bir önceki hafta karşılaştırması
			// (Bugünkü hafta henüz tamamlanmadı, daha sağlıklı karşılaştırma)
			VAR _last = [Last Week kWh v14]
			VAR _maxDate = CALCULATE(MAX(gold_kpi_daily[date]), REMOVEFILTERS('''Date'''))
			VAR _twoWeeksAgo = CALCULATE(
			    [Total Consumption kWh],
			    REMOVEFILTERS('''Date'''),
			    DATESINPERIOD(gold_kpi_daily[date], _maxDate - 7, -7, DAY)
			)
			RETURN
			DIVIDE(_last - _twoWeeksAgo, _twoWeeksAgo, BLANK()) * 100
		formatString: #,##0.0
		lineageTag: 766da1eb-7e77-43f2-a675-8d08607e3db1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Card: Last Month vs Previous Month Pct' =
			
			// Page 1 KPI card: Geçen ay / bir önceki ay
			VAR _lastMonth = [Last Month kWh v14]
			VAR _prevMonth = CALCULATE(
			    [Total Consumption kWh],
			    PREVIOUSMONTH(DATESINPERIOD('''Date'''[Date], MIN('''Date'''[Date]), 0, DAY))
			)
			RETURN
			DIVIDE(_lastMonth - _prevMonth, _prevMonth, BLANK()) * 100
		formatString: #,##0.0
		lineageTag: 9b39d242-224b-407e-bc5c-3a93cf486ba5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Card: Weekly Avg Consumption kWh' =
			
			// Son 4 haftanın haftalık ortalama tüketimi — trend baseline için
			VAR _maxDate = CALCULATE(MAX(gold_kpi_daily[date]), REMOVEFILTERS('''Date'''))
			VAR _28days = CALCULATE(
			    [Total Consumption kWh],
			    REMOVEFILTERS('''Date'''),
			    DATESINPERIOD(gold_kpi_daily[date], _maxDate, -28, DAY)
			)
			RETURN
			DIVIDE(_28days, 4, BLANK())
		formatString: #,##0.0
		lineageTag: 6be98438-281b-435d-854b-14850785645c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

