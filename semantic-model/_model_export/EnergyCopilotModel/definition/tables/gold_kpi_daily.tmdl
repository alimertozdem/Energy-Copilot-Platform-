	measure 'Monthly Actual kWh' = VAR _v = SUM ( gold_kpi_daily[total_consumption_kwh] ) RETURN IF ( ISBLANK ( _v ), BLANK (), _v )
		formatString: #,##0
		lineageTag: b466b2ad-e7e7-4f83-b7aa-2c8604da11dc

	measure 'Monthly Forecast kWh' = VAR _maxActualDate = MAXX ( ALL ( gold_kpi_daily ), gold_kpi_daily[date] ) VAR _firstPureForecastMonthStart = DATE ( YEAR ( EDATE ( _maxActualDate, 1 ) ), MONTH ( EDATE ( _maxActualDate, 1 ) ), 1 ) VAR _minForecastInContext = MIN ( gold_consumption_forecast[forecast_date] ) RETURN IF ( NOT ISBLANK ( _minForecastInContext ) && _minForecastInContext >= _firstPureForecastMonthStart, SUM ( gold_consumption_forecast[predicted_kwh] ), BLANK () )
		formatString: #,##0
		lineageTag: 970342b5-f159-4d37-bceb-1093d90d83a6

	measure 'Monthly PY kWh' =
			VAR _curDate = MAX ( gold_kpi_daily[date] )
			VAR _pyStartDate = DATE ( YEAR ( _curDate ) - 1, MONTH ( _curDate ), 1 )
			VAR _pyEndDate = EDATE ( _pyStartDate, 1 ) - 1
			RETURN
			CALCULATE (
			    SUM ( gold_kpi_daily[total_consumption_kwh] ),
			    REMOVEFILTERS ( '''Date''' ),
			    gold_kpi_daily[date] >= _pyStartDate,
			    gold_kpi_daily[date] <= _pyEndDate
			)
		formatString: #,##0
		lineageTag: 2596878b-0d73-415e-9a18-43e93c6355f2

	measure 'Monthly Actual Cost EUR' = VAR _v = SUM ( gold_kpi_daily[estimated_cost_eur] ) RETURN IF ( ISBLANK ( _v ), BLANK (), _v )
		formatString: "€" #,##0
		lineageTag: 6a9e8a6d-1c71-4779-b530-71d71fa67f50

	measure 'Monthly YoY Change Pct' = VAR _current = SUM ( gold_kpi_daily[total_consumption_kwh] ) VAR _py = [Monthly PY kWh] RETURN IF ( NOT ISBLANK ( _current ) && NOT ISBLANK ( _py ) && _py > 0, ROUND ( DIVIDE ( _current - _py, _py ) * 100, 1 ), BLANK () )
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: 7a06b175-0354-497f-b6dd-506a966b4833

	measure 'Monthly Forecast vs PY Pct' = VAR _forecast = [Monthly Forecast kWh] VAR _py = [Monthly PY kWh] RETURN IF ( NOT ISBLANK ( _forecast ) && NOT ISBLANK ( _py ) && _py > 0, ROUND ( DIVIDE ( _forecast - _py, _py ) * 100, 1 ), BLANK () )
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: f594d1ec-9e46-4391-8061-8f9f2f51e70f

	measure 'Ghost Load Annual Cost EUR' = ```
			
			VAR _after_hours_avg = 
			    CALCULATE(
			        AVERAGE( gold_occupancy_profile[occupancy_probability] ),
			        gold_occupancy_profile[hour_of_day] >= 20
			            || gold_occupancy_profile[hour_of_day] < 7
			    )
			VAR _total_avg = AVERAGE( gold_occupancy_profile[occupancy_probability] )
			VAR _phantom_pct = 
			    IF( _total_avg > 0,
			        DIVIDE( _after_hours_avg, _total_avg ) * 100,
			        BLANK()
			    )
			VAR _selected_buildings = DISTINCTCOUNT( gold_occupancy_profile[building_id] )
			VAR _building_type = 
			    IF(
			        _selected_buildings = 1,
			        CALCULATE(
			            SELECTEDVALUE( silver_building_master[building_type] ),
			            TREATAS( VALUES( gold_occupancy_profile[building_id] ),
			                     silver_building_master[building_id] )
			        ),
			        "Portfolio"
			    )
			VAR _critical_threshold = 
			    SWITCH(
			        TRUE(),
			        _building_type IN { "Hotel", "Healthcare" }, 130,
			        _building_type = "Logistics", 60,
			        35
			    )
			VAR _annual_kwh = CALCULATE( SUM( gold_kpi_daily[total_consumption_kwh] ) )
			VAR _baseload_factor = 0.20
			VAR _eur_per_kwh = 0.20
			VAR _excess_pct = MAX( _phantom_pct - _critical_threshold, 0 )
			VAR _wasted_kwh = _annual_kwh * ( _excess_pct / 100 ) * _baseload_factor
			VAR _wasted_eur = _wasted_kwh * _eur_per_kwh
			RETURN
			    IF(
			        NOT ISBLANK( _phantom_pct )
			            && _phantom_pct >= _critical_threshold
			            && _wasted_eur > 0,
			        ROUND( _wasted_eur, 0 ),
			        BLANK()
			    )
			```
		formatString: "€"#,##0
		displayFolder: Page 5 - Decision Support
		lineageTag: 860b7c14-48aa-4054-a822-50cd3205f75a

	measure 'Avg Climate-Adjusted EUI' = AVERAGE( gold_kpi_daily[climate_adjusted_eui] )
		formatString: #,##0.00
		displayFolder: Energy KPIs
		lineageTag: c86ac444-cb80-4ea8-8fbc-4617524b9ba4

	measure 'Avg Solar Specific Yield kWh kWp' =
			VAR _days = CALCULATE( DISTINCTCOUNT( gold_kpi_daily[date] ) )
			RETURN
			DIVIDE(
			    AVERAGEX(
			        VALUES( gold_kpi_daily[building_id] ),
			        DIVIDE(
			            CALCULATE( SUM( gold_kpi_daily[solar_generated_kwh] ) ),
			            CALCULATE( MAX( gold_kpi_daily[pv_capacity_kwp] ) )
			        )
			    ) * 365.0,
			    _days
			)
		formatString: #,##0
		displayFolder: Solar - Realtime & Opportunity
		lineageTag: 9184dc33-d57e-40b2-83aa-167e9c84062a

	measure 'Solar Self-Consumption Rate Pct' = DIVIDE( [Solar Self Consumed kWh], [Total Solar Generated kWh] )
		formatString: 0.0%
		displayFolder: Solar - Realtime & Opportunity
		lineageTag: 3c20f742-c0fe-45f6-9e64-df6b39f16085

	measure 'Renewable Rate Solar Sites Pct' =
			VAR _solarBuildings = FILTER( VALUES( silver_building_master[building_id] ), CALCULATE( SUM( silver_building_master[pv_capacity_kwp] ) ) > 0 )
			VAR _gen = CALCULATE( [Total Solar Generated kWh], KEEPFILTERS( _solarBuildings ) )
			VAR _con = CALCULATE( [Total Consumption kWh], KEEPFILTERS( _solarBuildings ) )
			RETURN DIVIDE( _gen, _con, 0 ) * 100
		formatString: #,##0.0
		displayFolder: Solar - Realtime & Opportunity
		lineageTag: da16f7af-e31f-4359-b599-0901ff958b9c

