	measure 'Total Solar Generated kWh KPI' =
			VAR _maxd = CALCULATE ( MAX ( gold_kpi_daily[date] ), ALLSELECTED ( gold_kpi_daily[date] ) )
			VAR _from = _maxd - 364
			RETURN
			CALCULATE (
			    SUM ( gold_kpi_daily[solar_generated_kwh] ),
			    ALLSELECTED ( gold_kpi_daily[date] ),
			    gold_kpi_daily[date] >= _from && gold_kpi_daily[date] <= _maxd
			)
		formatString: #,##0
		displayFolder: Page 2 - Building Detail
		lineageTag: dcbf72a3-b4e6-4005-ba3f-2aee98708a44

	measure 'Avg Carbon Intensity kg m2 KPI' = CALCULATE(AVERAGEX(FILTER(gold_kpi_daily, gold_kpi_daily[carbon_intensity_kg_m2] <> BLANK()), gold_kpi_daily[carbon_intensity_kg_m2]), ALLSELECTED())
		formatString: 0.000 "kgCO2/m2"
