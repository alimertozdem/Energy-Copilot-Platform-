	measure 'Building EUI (kWh/m2, period)' = DIVIDE ( SUM ( gold_kpi_daily[total_consumption_kwh] ), MAX ( gold_kpi_daily[floor_area_m2] ) )
		lineageTag: 48fb6f09-da34-487c-ae58-102f89f61872

