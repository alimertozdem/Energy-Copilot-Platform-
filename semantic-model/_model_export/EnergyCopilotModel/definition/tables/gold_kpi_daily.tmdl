	measure 'Avg EUI Area-Weighted (kWh/m2/day)' =
			
			DIVIDE (
			    SUM ( gold_kpi_daily[total_consumption_kwh] ),
			    SUMX ( VALUES ( gold_kpi_daily[building_id] ),
			           CALCULATE ( MAX ( gold_kpi_daily[floor_area_m2] ) ) )
			    * DISTINCTCOUNT ( gold_kpi_daily[date] )
			)
		lineageTag: 92ee22ee-ff93-47bc-bd48-5eea4070b215

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg EUI Annual kWh m2 yr' = [Avg EUI Area-Weighted (kWh/m2/day)] * 365.25
		formatString: #,##0
		displayFolder: EUI
		lineageTag: a1b6b6b8-c4fe-4435-88fa-2b6db6c5f468

	measure 'EUI Target Annual kWh m2 yr' =
			VAR _benchOf =
			    // per-building annual EUI benchmark (kWh/m2/yr) by building_type
			    SUMX (
			        VALUES ( silver_building_master[building_id] ),
			        VAR _bt = LOWER ( CALCULATE ( SELECTEDVALUE ( silver_building_master[building_type] ) ) )
			        VAR _area = CALCULATE ( SUM ( silver_building_master[conditioned_area_m2] ) )
			        VAR _b =
			            SWITCH (
			                TRUE (),
			                CONTAINSSTRING ( _bt, "data" ),       1700,
			                CONTAINSSTRING ( _bt, "health" ),      300,
			                CONTAINSSTRING ( _bt, "hospital" ),    300,
			                CONTAINSSTRING ( _bt, "lab" ),         400,
			                CONTAINSSTRING ( _bt, "hotel" ),       240,
			                CONTAINSSTRING ( _bt, "logistic" ),    90,
			                CONTAINSSTRING ( _bt, "warehouse" ),   90,
			                CONTAINSSTRING ( _bt, "educat" ),      120,
			                CONTAINSSTRING ( _bt, "office" ),      130,
			                CONTAINSSTRING ( _bt, "residential" ), 100,
			                150   // default
			            )
			        RETURN _area * _b
			    )
			VAR _area = SUMX ( VALUES ( silver_building_master[building_id] ),
			                   CALCULATE ( SUM ( silver_building_master[conditioned_area_m2] ) ) )
			RETURN
			    DIVIDE ( _benchOf, _area )
		formatString: #,##0
		displayFolder: EUI
		lineageTag: e9e28cca-60dc-4126-aff6-24205cce54f9

	measure 'EUI vs Target Pct' =
			VAR _e = [Avg EUI Annual kWh m2 yr]
			VAR _g = [EUI Target Annual kWh m2 yr]
			RETURN IF ( _g > 0, DIVIDE ( _e - _g, _g ), BLANK () )
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: EUI
		lineageTag: 5e1d6bfe-b456-4e12-a772-afc108f0ca58

	measure 'Solar Generated kWh Rolling 12m' =
			VAR _maxd = MAXX ( ALL ( gold_kpi_daily ), gold_kpi_daily[date] )
			VAR _from = _maxd - 364
			VAR _bldgs = VALUES ( silver_building_master[building_id] )
			RETURN
			CALCULATE (
			    SUM ( gold_kpi_daily[solar_generated_kwh] ),
			    REMOVEFILTERS ( gold_kpi_daily[date] ),
			    gold_kpi_daily[date] >= _from && gold_kpi_daily[date] <= _maxd,
			    TREATAS ( _bldgs, gold_kpi_daily[building_id] )
			)
		formatString: #,##0 "kWh"
		displayFolder: Solar
		lineageTag: f718e5af-1f2f-45b5-ad25-cea04d57a749

	measure 'Solar CO2 Avoided tCO2 Rolling 12m' =
			VAR _maxd = MAXX ( ALL ( gold_kpi_daily ), gold_kpi_daily[date] )
			VAR _from = _maxd - 364
			VAR _bldgs = VALUES ( silver_building_master[building_id] )
			RETURN
			CALCULATE (
			    DIVIDE ( SUM ( gold_kpi_daily[co2_savings_from_solar_kg] ), 1000 ),
			    REMOVEFILTERS ( gold_kpi_daily[date] ),
			    gold_kpi_daily[date] >= _from && gold_kpi_daily[date] <= _maxd,
			    TREATAS ( _bldgs, gold_kpi_daily[building_id] )
			)
		formatString: #,##0.0
		displayFolder: Solar
		lineageTag: 35b3f2a0-3613-4765-a870-61f10b9f574b

	measure 'Solar Self Consumed kWh Rolling 12m' =
			VAR _maxd = MAXX ( ALL ( gold_kpi_daily ), gold_kpi_daily[date] )
			VAR _from = _maxd - 364
			VAR _bldgs = VALUES ( silver_building_master[building_id] )
			RETURN
			CALCULATE (
			    SUM ( gold_kpi_daily[solar_self_consumed_kwh] ),
			    REMOVEFILTERS ( gold_kpi_daily[date] ),
			    gold_kpi_daily[date] >= _from && gold_kpi_daily[date] <= _maxd,
			    TREATAS ( _bldgs, gold_kpi_daily[building_id] )
			)
		formatString: #,##0
		displayFolder: Solar
		lineageTag: 37d5e8e9-1202-45c3-8ade-6398c9cd4770

	measure 'Solar Exported kWh Rolling 12m' =
			VAR _maxd = MAXX ( ALL ( gold_kpi_daily ), gold_kpi_daily[date] )
			VAR _from = _maxd - 364
			VAR _bldgs = VALUES ( silver_building_master[building_id] )
			RETURN
			CALCULATE (
			    SUM ( gold_kpi_daily[solar_exported_kwh] ),
			    REMOVEFILTERS ( gold_kpi_daily[date] ),
			    gold_kpi_daily[date] >= _from && gold_kpi_daily[date] <= _maxd,
			    TREATAS ( _bldgs, gold_kpi_daily[building_id] )
			)
		formatString: #,##0
		displayFolder: Solar
		lineageTag: 27b5d00f-4266-4248-8651-6c8963b04a2b

