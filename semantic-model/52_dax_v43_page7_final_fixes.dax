// ==========================================================================
// DAX v43 — PAGE 7 HVAC & Building Envelope — FINAL FIXES + ENGLISH + TIME INTEL
// Energy Copilot Platform — 2026-05-06
//
// Changes from v40/v41/v42:
//   (1) BUG FIX: renovation_priority filter was integer (1/2/3) → now string ("High"/"Medium"/"Low")
//   (2) BUG FIX: HVAC Efficiency shows "58.7999..." → ROUND added
//   (3) BUG FIX: Gas Exposure shows "—" when 0 gas buildings → COALESCE fix
//   (4) BUG FIX: EPC Compliance shows "—" when 0 compliant → COALESCE fix
//   (5) ALL LABELS: fully English (no Turkish text anywhere)
//   (6) TIME INTELLIGENCE: YoY + MoM measures for all major KPIs
//
// HOW TO APPLY:
//   Step 1 — Import all measures below as "New measure" (assign to gold_hvac_analytics)
//   Step 2 — Per-card binding guide at the bottom of this file
// ==========================================================================


// ==========================================================================
// SECTION 1 — CARD CALLOUT MEASURES (main numeric values)
// ==========================================================================

// ── C1: HVAC Share % ──────────────────────────────────────────────────────

Card: HVAC Share v43 =
VAR _pct = AVERAGE ( gold_hvac_analytics[hvac_share_pct] )
RETURN
    IF ( ISBLANK ( _pct ), "—", FORMAT ( ROUND ( _pct, 1 ), "0.0" ) & "%" )
// Expected (portfolio All): 35–55%  |  Healthcare B005: 45–65%


// ── C2: HVAC Efficiency Score ─────────────────────────────────────────────
// BUG FIX: previous measure missing ROUND → showed "58.7999999..."

Card: HVAC Efficiency v43 =
VAR _score = AVERAGE ( gold_hvac_analytics[hvac_efficiency_score] )
RETURN
    IF ( ISBLANK ( _score ), "—", FORMAT ( ROUND ( _score, 0 ), "0" ) )
// Scale: 0–100.  Gas buildings cap at 50.  Heat pump with good insulation: 70–85.
// Expected (Berliner HP): ~70–80  |  Gas boiler portfolio: ~35–50


// ── C3: Avg Insulation Score ──────────────────────────────────────────────

Card: Avg Insulation v43 =
VAR _score = AVERAGE ( gold_hvac_analytics[insulation_score] )
RETURN
    IF ( ISBLANK ( _score ), "—", FORMAT ( ROUND ( _score, 0 ), "0" ) & " / 100" )
// Expected (All): 65–75  |  Berliner: 86+  |  Amsterdam: ~55


// ── C4: Heat Loss Annual (×12 fix) ────────────────────────────────────────

Card: Heat Loss v43 =
VAR _hl_monthly = AVERAGE ( gold_hvac_analytics[heat_loss_kwh_m2] )
VAR _hl_annual  = _hl_monthly * 12
RETURN
    IF ( ISBLANK ( _hl_monthly ), "—", FORMAT ( ROUND ( _hl_annual, 0 ), "0" ) & " kWh/m²·yr" )
// Expected: 30–150 kWh/m²·yr  |  Berliner: ~35–55  |  Frankfurt gas: ~90–130


// ── C5: Buildings For Retrofit ────────────────────────────────────────────
// BUG FIX: was filtering renovation_priority = 1 (integer) — column stores "High"/"Medium"/"Low"

Card: Buildings For Retrofit v43 =
VAR _cnt =
    COALESCE (
        CALCULATE (
            DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
            gold_hvac_analytics[renovation_priority] = "High"
        ),
        0
    )
RETURN FORMAT ( _cnt, "0" )
// Expected (All): 2 (Istanbul + Frankfurt gas with lower insulation)
// Single building select: 0 or 1


// ── C6: HVAC CO₂ tCO₂/yr ─────────────────────────────────────────────────

Card: HVAC CO2 v43 =
VAR _gasF  = 0.2017   // kgCO₂/kWh — natural gas Scope 1 (BAFA/IPCC 2024)
VAR _elecF = 0.350    // kgCO₂e/kWh — EU grid average Scope 2 (EEA 2024)
VAR _total_kg =
    SUMX (
        VALUES ( gold_hvac_analytics[building_id] ),
        VAR _bid  = gold_hvac_analytics[building_id]
        VAR _sys  =
            CALCULATE ( MAX ( gold_hvac_analytics[system_type] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _isS1 = _sys = "gas_boiler" || _sys = "hybrid" || _sys = "biomass"
        VAR _hkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[heating_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _ckwh =
            CALCULATE ( SUM ( gold_hvac_analytics[cooling_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _vkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[ventilation_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _hkg = IF ( _isS1, COALESCE(_hkwh,0)*_gasF, COALESCE(_hkwh,0)*_elecF )
        RETURN _hkg + COALESCE(_ckwh,0)*_elecF + COALESCE(_vkwh,0)*_elecF
    )
RETURN
    IF ( ISBLANK ( _total_kg ), "—",
         FORMAT ( ROUND ( DIVIDE ( _total_kg, 1000 ), 1 ), "0.0" ) & " tCO₂" )


// ── C7: Gas Exposure % ────────────────────────────────────────────────────
// BUG FIX: returned "—" when 0 gas buildings visible (e.g. Amsterdam VRF selected)
// COALESCE converts BLANK→0 before DIVIDE

Card: Gas Exposure v43 =
VAR _gas_cnt =
    COALESCE (
        CALCULATE (
            DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
            gold_hvac_analytics[system_type] IN { "gas_boiler", "hybrid", "biomass" }
        ),
        0
    )
VAR _total = COALESCE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ), 0 )
VAR _pct   = IF ( _total = 0, BLANK(), DIVIDE ( _gas_cnt, _total ) * 100 )
RETURN
    IF ( ISBLANK ( _pct ), "—", FORMAT ( ROUND ( _pct, 0 ), "0" ) & "%" )
// Portfolio (3 gas / 6 total): 50%
// Amsterdam only (VRF): 0%  — now correctly shows "0%" not "—"


// ── C8: EPC Compliance ────────────────────────────────────────────────────
// BUG FIX: returned "—" when 0 compliant buildings (COALESCE fix)
// BUG FIX: threshold was <= 90 on monthly value → correct is <= 7.5 (90/12)

Card: EPC Compliance v43 =
VAR _compliant =
    COALESCE (
        CALCULATE (
            DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
            gold_hvac_analytics[insulation_score]  >= 65,
            gold_hvac_analytics[heat_loss_kwh_m2]  <= 7.5   // monthly → 7.5 × 12 = 90 kWh/m²·yr
        ),
        0
    )
VAR _total = COALESCE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ), 0 )
RETURN
    IF ( _total = 0, "—",
         FORMAT ( _compliant, "0" ) & " / " & FORMAT ( _total, "0" ) & " buildings" )
// Expected (All): 3 / 6 buildings  |  Berliner, Munich, Rotterdam expected compliant


// ==========================================================================
// SECTION 2 — REFERENCE LABEL MEASURES (English, shown below callout)
// ==========================================================================

Card: HVAC Share Label v43 =
VAR _pct = AVERAGE ( gold_hvac_analytics[hvac_share_pct] )
RETURN
    SWITCH ( TRUE (),
        ISBLANK ( _pct ),  "No data",
        _pct >= 55,        "⚠️ High — CSRD Energy Risk",
        _pct >= 42,        "🟡 Above EU Average (42–55%)",
        _pct >= 30,        "✅ Normal Range (30–42%)",
                           "ℹ️ Low HVAC Share (<30%)"
    )


Card: HVAC Efficiency Label v43 =
VAR _score = AVERAGE ( gold_hvac_analytics[hvac_efficiency_score] )
RETURN
    SWITCH ( TRUE (),
        ISBLANK ( _score ),  "No data",
        _score >= 75,        "🟢 High Efficiency — NZEB Ready",
        _score >= 60,        "🟡 Moderate — Improvement Advised",
        _score >= 40,        "🟠 Low — Retrofit Recommended",
                             "🔴 Poor — Urgent Action Required"
    )


Card: Insulation Label v43 =
VAR _score = AVERAGE ( gold_hvac_analytics[insulation_score] )
RETURN
    SWITCH ( TRUE (),
        ISBLANK ( _score ),  "No data",
        _score >= 80,        "🟢 EPC A/B — NZEB Ready",
        _score >= 65,        "🟡 EPC C — Improvement Advised",
        _score >= 50,        "🟠 EPC D — Below GEG Limit",
        _score >= 35,        "🔴 EPC E/F — Retrofit Required",
                             "🔴 EPC G — Urgent Action"
    )


Card: Heat Loss Label v43 =
VAR _hl_monthly = AVERAGE ( gold_hvac_analytics[heat_loss_kwh_m2] )
VAR _hl         = _hl_monthly * 12
RETURN
    SWITCH ( TRUE (),
        ISBLANK ( _hl ),  "No data",
        _hl <= 30,        "🟢 Passive House Level",
        _hl <= 55,        "🟢 EPC A — NZEB Compliant",
        _hl <= 90,        "🟡 EPC B/C — EU Average",
        _hl <= 150,       "🟠 EPC D/E — High Loss",
                          "🔴 EPC F/G — Critical Loss"
    )


// BUG FIX: was filtering renovation_priority = 1/2 (integer) — correct values are strings
Card: Retrofit Label v43 =
VAR _high  =
    COALESCE ( CALCULATE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
        gold_hvac_analytics[renovation_priority] = "High" ),   0 )
VAR _med   =
    COALESCE ( CALCULATE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
        gold_hvac_analytics[renovation_priority] = "Medium" ), 0 )
VAR _total = COALESCE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ), 0 )
RETURN
    FORMAT ( _high, "0" ) & " urgent  ·  " &
    FORMAT ( _med,  "0" ) & " planned  ·  " &
    FORMAT ( _total - _high - _med, "0" ) & " OK"
// Expected (All, 6 bldg): "2 urgent  ·  1 planned  ·  3 OK"


Card: CO2 Label v43 =
VAR _gasF  = 0.2017
VAR _elecF = 0.350
VAR _s1_kg =
    SUMX (
        VALUES ( gold_hvac_analytics[building_id] ),
        VAR _bid  = gold_hvac_analytics[building_id]
        VAR _sys  =
            CALCULATE ( MAX ( gold_hvac_analytics[system_type] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _isS1 = _sys = "gas_boiler" || _sys = "hybrid" || _sys = "biomass"
        VAR _hkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[heating_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        RETURN IF ( _isS1, COALESCE(_hkwh,0)*_gasF, 0 )
    )
VAR _total_kg =
    SUMX (
        VALUES ( gold_hvac_analytics[building_id] ),
        VAR _bid  = gold_hvac_analytics[building_id]
        VAR _sys  =
            CALCULATE ( MAX ( gold_hvac_analytics[system_type] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _isS1 = _sys = "gas_boiler" || _sys = "hybrid" || _sys = "biomass"
        VAR _hkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[heating_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _ckwh =
            CALCULATE ( SUM ( gold_hvac_analytics[cooling_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _vkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[ventilation_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        RETURN
            IF ( _isS1, COALESCE(_hkwh,0)*_gasF, COALESCE(_hkwh,0)*_elecF )
            + COALESCE(_ckwh,0)*_elecF + COALESCE(_vkwh,0)*_elecF
    )
VAR _s1_pct = ROUND ( DIVIDE ( _s1_kg, _total_kg ) * 100, 0 )
RETURN
    IF ( ISBLANK ( _total_kg ), "No data",
         "Scope 1: " & FORMAT ( _s1_pct, "0" ) & "%  ·  " &
         "Scope 2: " & FORMAT ( 100 - _s1_pct, "0" ) & "%" )
// Expected (gas-heavy portfolio): "Scope 1: 65%  ·  Scope 2: 35%"


Card: Gas Exposure Label v43 =
VAR _gas_cnt =
    COALESCE (
        CALCULATE (
            DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
            gold_hvac_analytics[system_type] IN { "gas_boiler", "hybrid", "biomass" }
        ),
        0
    )
VAR _total = COALESCE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ), 0 )
VAR _pct   = IF ( _total = 0, 0, ROUND ( DIVIDE ( _gas_cnt, _total ) * 100, 0 ) )
RETURN
    IF ( _total = 0, "No data",
        SWITCH ( TRUE (),
            _pct >= 80,  "🔴 Critical — High Transition Risk",
            _pct >= 50,  "🟠 High — CSRD Disclosure Required",
            _pct >= 25,  "🟡 Medium — Transition Plan Needed",
            _pct > 0,    "🟢 Low Fossil Dependency",
                         "🟢 Zero Fossil Heating"
        )
    )


Card: EPC Label v43 =
VAR _compliant =
    COALESCE (
        CALCULATE (
            DISTINCTCOUNT ( gold_hvac_analytics[building_id] ),
            gold_hvac_analytics[insulation_score]  >= 65,
            gold_hvac_analytics[heat_loss_kwh_m2]  <= 7.5
        ),
        0
    )
VAR _total = COALESCE ( DISTINCTCOUNT ( gold_hvac_analytics[building_id] ), 0 )
VAR _pct   = IF ( _total = 0, 0, ROUND ( DIVIDE ( _compliant, _total ) * 100, 0 ) )
RETURN
    IF ( _total = 0, "No data",
        SWITCH ( TRUE (),
            _pct >= 80,  "🟢 EPC D+ Compliant",
            _pct >= 50,  "🟡 Partial — EPBD 2030 Risk",
                         "🔴 Most EPC E/F/G — Urgent"
        ) & "  (EPBD target: EPC E+)"
    )


// ==========================================================================
// SECTION 3 — TIME INTELLIGENCE: YoY + MoM MEASURES
// Requirement: Date table relationship active with gold_hvac_analytics
// ==========================================================================

// ── CO₂ Year-over-Year ────────────────────────────────────────────────────
// Use as: C6 card tooltip  OR  secondary reference label
// ▼ = improvement (good)  |  ▲ = increase (bad)

Card: CO2 YoY v43 =
VAR _gasF  = 0.2017
VAR _elecF = 0.350
VAR _calc_co2 =
    SUMX (
        VALUES ( gold_hvac_analytics[building_id] ),
        VAR _bid  = gold_hvac_analytics[building_id]
        VAR _sys  =
            CALCULATE ( MAX ( gold_hvac_analytics[system_type] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _isS1 = _sys = "gas_boiler" || _sys = "hybrid" || _sys = "biomass"
        VAR _hkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[heating_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _ckwh =
            CALCULATE ( SUM ( gold_hvac_analytics[cooling_energy_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        VAR _vkwh =
            CALCULATE ( SUM ( gold_hvac_analytics[ventilation_kwh] ),
                FILTER ( gold_hvac_analytics, gold_hvac_analytics[building_id] = _bid ) )
        RETURN
            IF ( _isS1, COALESCE(_hkwh,0)*_gasF, COALESCE(_hkwh,0)*_elecF )
            + COALESCE(_ckwh,0)*_elecF + COALESCE(_vkwh,0)*_elecF
    )
VAR _curr = _calc_co2
VAR _prev = CALCULATE ( _calc_co2, DATEADD ( 'Date'[Date], -1, YEAR ) )
VAR _chg  = DIVIDE ( _curr - _prev, _prev ) * 100
RETURN
    IF ( ISBLANK ( _prev ) || _prev = 0, "No prior year",
        IF ( _chg <= 0,
             "▼ " & FORMAT ( ABS ( _chg ), "0.0" ) & "% YoY ✅",
             "▲ " & FORMAT ( _chg, "0.0" ) & "% YoY ⚠️"
        )
    )


// ── HVAC Share Month-over-Month ───────────────────────────────────────────
// Use as: C1 card tooltip

Card: HVAC Share MoM v43 =
VAR _curr = AVERAGE ( gold_hvac_analytics[hvac_share_pct] )
VAR _prev = CALCULATE (
    AVERAGE ( gold_hvac_analytics[hvac_share_pct] ),
    DATEADD ( 'Date'[Date], -1, MONTH )
)
VAR _diff = _curr - _prev
RETURN
    IF ( ISBLANK ( _prev ), "—",
        IF ( _diff >= 0,
             "▲ " & FORMAT ( ABS ( _diff ), "0.1" ) & "% vs prev month",
             "▼ " & FORMAT ( ABS ( _diff ), "0.1" ) & "% vs prev month"
        )
    )


// ── Heat Loss Year-over-Year ──────────────────────────────────────────────
// Use as: C4 card tooltip

Card: Heat Loss YoY v43 =
VAR _curr = AVERAGE ( gold_hvac_analytics[heat_loss_kwh_m2] ) * 12
VAR _prev = CALCULATE (
    AVERAGE ( gold_hvac_analytics[heat_loss_kwh_m2] ) * 12,
    DATEADD ( 'Date'[Date], -1, YEAR )
)
VAR _chg = DIVIDE ( _curr - _prev, _prev ) * 100
RETURN
    IF ( ISBLANK ( _prev ), "No prior year",
        IF ( _chg <= 0,
             "▼ " & FORMAT ( ABS ( _chg ), "0.0" ) & "% vs prior year ✅",
             "▲ " & FORMAT ( _chg, "0.0" ) & "% vs prior year ⚠️"
        )
    )


// ── Insulation Score Year-over-Year ──────────────────────────────────────
// Use as: C3 card tooltip

Card: Insulation YoY v43 =
VAR _curr = CALCULATE (
    AVERAGE ( gold_hvac_analytics[insulation_score] ), ALLSELECTED ( gold_hvac_analytics ) )
VAR _prev = CALCULATE (
    AVERAGE ( gold_hvac_analytics[insulation_score] ),
    ALLSELECTED ( gold_hvac_analytics ),
    DATEADD ( 'Date'[Date], -1, YEAR )
)
VAR _diff = _curr - _prev
RETURN
    IF ( ISBLANK ( _prev ), "—",
        IF ( _diff >= 0,
             "▲ " & FORMAT ( _diff, "0.0" ) & " pts YoY ✅",
             "▼ " & FORMAT ( ABS ( _diff ), "0.0" ) & " pts YoY ⚠️"
        )
    )


// ── V1: Prior Year Heating Series ─────────────────────────────────────────
// Add as second Y-axis series on V1 bar chart → shows prior year heating line
// Color: #FF6B35 dashed  |  Legend: "Prior Year Heating"

Heating Prior Year v43 =
CALCULATE (
    SUM ( gold_hvac_analytics[heating_energy_kwh] ),
    DATEADD ( 'Date'[Date], -1, YEAR )
)


